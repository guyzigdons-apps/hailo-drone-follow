      "min": 0.01,
      "max": 1.0,
      "step": 0.01,
      "group": "yaw",
      "order": 2,
      "label": "Yaw smoothing (α)",
      "description": "Low-pass filter coefficient — lower = smoother",
      "read_only": false
    },
    {
      "id": "smooth_yaw",
      "mavlink_id": "DF_SMTH_YAW",
      "type": "bool",
      "default": true,
      "group": "yaw",
      "order": 3,
      "label": "Smooth yaw",
      "description": "Enable exponential smoothing on yaw commands",
      "read_only": false
    },
    {
      "id": "yaw_only",
      "mavlink_id": "DF_YAW_ONLY",
