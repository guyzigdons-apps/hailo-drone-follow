      "step": 0.1,
      "group": "fwd",
      "order": 3,
      "label": "Max forward speed (m/s)",
      "description": "Clamp forward velocity to this limit",
      "read_only": false
    },
    {
      "id": "max_backward",
      "mavlink_id": "DF_MAX_BACK",
      "type": "float",
      "default": 3.0,
      "min": 0.0,
      "max": 10.0,
      "step": 0.1,
      "group": "fwd",
      "order": 4,
      "label": "Max backward speed (m/s)",
      "description": "Clamp backward velocity to this limit",
      "read_only": false
    },
    {
      "id": "forward_alpha",
      "mavlink_id": "DF_FWD_ALPHA",
      "type": "float",
      "default": 0.1,
      "min": 0.01,
      "max": 1.0,
      "step": 0.01,
      "group": "fwd",
      "order": 5,
      "label": "Forward smoothing (α)",
      "description": "Low-pass filter coefficient for forward/backward commands",
      "read_only": false
    },
    {
      "id": "smooth_forward",
      "mavlink_id": "DF_SMTH_FWD",
      "type": "bool",
      "default": true,
      "group": "fwd",
      "order": 6,
      "label": "Smooth forward",
      "description": "Enable exponential smoothing on forward/backward commands",
      "read_only": false
    },
    {
      "id": "target_distance_m",
      "mavlink_id": "DF_TGT_DIST",
