{
  "version": 1,
  "groups": [
    {"id": "yaw",    "label": "YAW CONTROL",         "order": 1},
    {"id": "fwd",    "label": "FORWARD / BACKWARD",   "order": 2},
    {"id": "target", "label": "TARGET & DEAD ZONE",    "order": 3},
    {"id": "flight", "label": "FLIGHT",                "order": 4},
    {"id": "track",  "label": "TRACKING",              "order": 5},
    {"id": "video",  "label": "VIDEO",                 "order": 6}
  ],
  "params": [
    {
      "id": "kp_yaw",
      "mavlink_id": "DF_KP_YAW",
      "type": "float",
      "default": 5.0,
      "min": 0.0,
      "max": 20.0,
      "step": 0.1,
      "group": "yaw",
      "order": 1,
      "label": "Yaw P-gain",
      "description": "Proportional gain for yaw rotation towards the target",
      "read_only": false
    },
    {
      "id": "yaw_alpha",
      "mavlink_id": "DF_YAW_ALPHA",
