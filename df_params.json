      "default": 0.0,
      "min": 0.0,
      "max": 50.0,
      "step": 0.5,
      "group": "target",
      "order": 1,
      "label": "Target distance (m)",
      "description": "Desired follow distance in metres (0 = disabled — distance keeping off)",
      "read_only": false
    },
    {
      "id": "dead_zone_height_percent",
      "mavlink_id": "DF_DZ_H_PCT",
      "type": "float",
      "default": 5.0,
      "min": 0.0,
      "max": 50.0,
      "step": 0.5,
      "group": "target",
      "order": 2,
      "label": "Dead-zone height (%)",
      "description": "Vertical dead-zone as a percentage of frame height. Target inside this zone → no movement.",
      "read_only": false
    },
    {
      "id": "takeoff_altitude",
      "mavlink_id": "DF_TAKEOFF_M",
      "type": "float",
      "default": 3.0,
      "min": 1.0,
      "max": 20.0,
      "step": 0.5,
      "group": "flight",
      "order": 1,
      "label": "Takeoff altitude (m)",
      "description": "Altitude used for automated takeoff",
      "read_only": false
    },
    {
      "id": "fixed_altitude",
      "mavlink_id": "DF_FIX_ALT",
      "type": "bool",
      "default": false,
      "group": "flight",
      "order": 2,
      "label": "Fixed altitude",
      "description": "When enabled, the drone maintains takeoff altitude and does not climb/descend",
      "read_only": false
    },
    {
      "id": "active_id",
      "mavlink_id": "DF_ACTIVE_ID",
      "type": "int",
      "default": 0,
      "min": 0,
      "max": 65535,
      "group": "track",
      "order": 1,
      "label": "Active tracked ID",
      "description": "Read-only — the person ID currently being followed (0 = none)",
      "read_only": true,
      "hidden": true
    },
    {
      "id": "follow_id",
      "mavlink_id": "DF_FOLLOW_ID",
      "type": "int",
      "default": 0,
      "min": -1,
      "max": 999,
      "step": 1,
      "group": "track",
      "order": 2,
      "label": "Follow ID",
      "description": "-1 = idle (hold position), 0 = auto (largest person), >0 = lock to specific ID",
      "read_only": false,
      "hidden": true
    },
    {
      "id": "bitrate_kbps",
      "mavlink_id": "DF_BITRATE",
      "type": "int",
      "default": 3917,
      "min": 500,
      "max": 20000,
      "step": 1,
      "group": "video",
      "order": 1,
      "label": "Bitrate (kbps)",
      "description": "x264 encoder bitrate for the drone-follow video stream. Updated by variable-bitrate automatically.",
      "read_only": false
    }
  ]
