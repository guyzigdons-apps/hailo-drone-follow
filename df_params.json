      "default": false,
      "group": "yaw",
      "order": 4,
      "label": "Yaw only (no forward)",
      "description": "Rotate towards the target but do not move forward/backward",
      "read_only": false
    },
    {
      "id": "kp_forward",
      "mavlink_id": "DF_KP_FWD",
      "type": "float",
      "default": 3.0,
      "min": 0.0,
      "max": 20.0,
      "step": 0.1,
      "group": "fwd",
      "order": 1,
      "label": "Forward P-gain",
      "description": "Proportional gain for moving towards the target",
      "read_only": false
    },
    {
      "id": "kp_backward",
      "mavlink_id": "DF_KP_BACK",
      "type": "float",
      "default": 5.0,
      "min": 0.0,
      "max": 20.0,
      "step": 0.1,
      "group": "fwd",
      "order": 2,
      "label": "Backward P-gain",
      "description": "Proportional gain for reversing away when too close",
      "read_only": false
    },
    {
      "id": "max_forward",
      "mavlink_id": "DF_MAX_FWD",
